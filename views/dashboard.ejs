<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Pelanggan | <%= customer.phone %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .navbar-glass {
      background: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.3);
    }
  </style>
</head>
<body class="pb-5">
  <nav class="navbar navbar-glass sticky-top mb-4">
    <div class="container d-flex justify-content-between align-items-center py-2">
      <span class="navbar-brand d-flex align-items-center gap-2 m-0 h5 fw-bold text-dark">
        <img src="/img/logo.png" alt="Logo" height="32" class="rounded-circle shadow-sm">
        Portal Pelanggan
      </span>
      <div class="d-flex align-items-center gap-3">
        <div class="d-none d-md-flex align-items-center">
          <% if (customer.status === 'Online') { %>
            <span class="pulse-online"></span>
            <span class="text-success fw-bold small">ONLINE</span>
          <% } else { %>
            <span class="text-secondary fw-bold small"><%= customer.status.toUpperCase() %></span>
          <% } %>
        </div>
        <form method="POST" action="/customer/logout" class="m-0">
          <button type="submit" class="btn btn-light btn-sm rounded-pill px-3 shadow-sm border">
            <i class="bi bi-box-arrow-right me-1"></i>Keluar
          </button>
        </form>
      </div>
    </div>
  </nav>

  <div class="container">
    <% if (typeof notif !== 'undefined' && notif && notif.text) { %>
      <div class="alert alert-premium rounded-4 border-0 shadow-sm mb-4 d-flex align-items-center justify-content-between <%= notif.type === 'danger' ? 'bg-danger text-white' : notif.type === 'warning' ? 'bg-warning text-dark' : 'bg-success text-white' %>" id="notif-alert">
        <div>
          <i class="bi <%= notif.type === 'danger' || notif.type === 'warning' ? 'bi-exclamation-triangle' : 'bi-check-circle' %> me-2"></i>
          <%= notif.text %>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <div class="row g-4">
      <!-- Welcome Card -->
      <div class="col-12">
        <div class="card-premium p-4 d-flex flex-column flex-md-row align-items-center justify-content-between gap-3">
          <div class="d-flex align-items-center gap-3">
            <div class="icon-box m-0" style="background: var(--primary-gradient); width: 60px; height: 60px; font-size: 24px;">
              <i class="bi bi-person-circle"></i>
            </div>
            <div>
              <h4 class="fw-bold mb-0">Selamat Datang, <%= customer.phone %></h4>
              <p class="text-muted mb-0 small">Kelola koneksi internet Anda dengan mudah di sini.</p>
            </div>
          </div>
          <button class="btn btn-outline-primary rounded-pill px-4" onclick="location.reload()">
            <i class="bi bi-arrow-clockwise me-1"></i>Refresh Data
          </button>
        </div>
      </div>

      <!-- Quick Stats -->
      <div class="col-6 col-md-3">
        <div class="stat-widget">
          <div class="icon-box" style="background: linear-gradient(135deg, #3b82f6, #2563eb);">
            <i class="bi bi-wifi"></i>
          </div>
          <div class="stat-label">WiFi SSID</div>
          <div class="stat-value"><%= customer.ssid %></div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-widget">
          <div class="icon-box" style="background: linear-gradient(135deg, #10b981, #059669);">
            <i class="bi bi-activity"></i>
          </div>
          <div class="stat-label">RX Power</div>
          <div class="stat-value"><%= customer.rxPower %></div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-widget">
          <div class="icon-box" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
            <i class="bi bi-people"></i>
          </div>
          <div class="stat-label">Terhubung</div>
          <div class="stat-value"><%= customer.totalAssociations %> Perangkat</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-widget">
          <div class="icon-box" style="background: linear-gradient(135deg, #8b5cf6, #7c3aed);">
            <i class="bi bi-clock-history"></i>
          </div>
          <div class="stat-label">Aktif Sejak</div>
          <div class="stat-value"><%= customer.uptime %></div>
        </div>
      </div>

      <!-- Settings Forms -->
      <div class="col-12 col-lg-6">
        <div class="card-premium h-100 p-4">
          <h5 class="fw-bold mb-4 d-flex align-items-center gap-2">
            <i class="bi bi-gear-fill text-primary"></i>
            Pengaturan WiFi
          </h5>
          
          <form method="POST" action="/customer/change-ssid" class="mb-4 cmd-form">
            <label class="form-label small fw-bold text-muted">NAMA WIFI (SSID)</label>
            <div class="input-group input-group-lg">
              <span class="input-group-text bg-white border-end-0 rounded-start-4"><i class="bi bi-wifi"></i></span>
              <input type="text" class="form-control border-start-0 ps-0 rounded-0" name="ssid" value="<%= customer.ssid !== '-' ? customer.ssid : '' %>" required maxlength="32">
              <button class="btn btn-primary-p px-4 rounded-end-4 btn-submit" type="submit">Ganti</button>
            </div>
            <p class="text-muted x-small mt-2 mb-0">Dual-band 5G akan otomatis menjadi <strong><%= customer.ssid %>-5G</strong></p>
          </form>

          <form method="POST" action="/customer/change-password" class="cmd-form">
            <label class="form-label small fw-bold text-muted">KATA SANDI WIFI</label>
            <div class="input-group input-group-lg">
              <span class="input-group-text bg-white border-end-0 rounded-start-4"><i class="bi bi-shield-lock"></i></span>
              <input type="password" class="form-control border-start-0 ps-0 rounded-0" name="password" placeholder="Min. 8 Karakter" required minlength="8">
              <button class="btn btn-primary-p px-4 rounded-end-4 btn-submit" type="submit">Simpan</button>
            </div>
          </form>
        </div>
      </div>

      <!-- Device Details & Reboot -->
      <div class="col-12 col-lg-6">
        <div class="card-premium h-100 p-4">
          <h5 class="fw-bold mb-4 d-flex align-items-center gap-2">
            <i class="bi bi-info-circle-fill text-info"></i>
            Detail Perangkat
          </h5>
          
          <div class="row g-3 mb-4">
            <div class="col-6">
              <div class="small text-muted mb-1">PPPoE Username</div>
              <div class="fw-bold"><%= customer.pppoeUsername %></div>
            </div>
            <div class="col-6">
              <div class="small text-muted mb-1">Alamat IP</div>
              <div class="fw-bold"><%= customer.pppoeIP %></div>
            </div>
            <div class="col-6">
              <div class="small text-muted mb-1">Model ONU</div>
              <div class="fw-bold"><%= customer.model %></div>
            </div>
            <div class="col-6">
              <div class="small text-muted mb-1">Software</div>
              <div class="fw-bold"><%= customer.softwareVersion %></div>
            </div>
            <div class="col-12">
              <div class="small text-muted mb-1">Serial Number</div>
              <div class="fw-bold font-monospace"><%= customer.serialNumber %></div>
            </div>
          </div>

          <div class="p-3 bg-light rounded-4 border text-center">
            <p class="text-muted small mb-3">Jika internet terasa lambat atau bermasalah, coba muat ulang perangkat Anda.</p>
            <button id="rebootBtn" class="btn btn-danger-p w-100 rounded-pill py-3">
              <i class="bi bi-arrow-repeat me-2"></i>REBOOT PERANGKAT SEKARANG
            </button>
          </div>
          <form id="rebootForm" method="POST" action="/customer/reboot" style="display:none;"></form>
        </div>
      </div>

      <!-- Connected Users Table -->
      <div class="col-12">
        <div class="card-premium p-4">
          <h5 class="fw-bold mb-4 d-flex align-items-center gap-2">
            <i class="bi bi-laptop text-success"></i>
            Daftar Perangkat Terhubung
          </h5>
          
          <% if (connectedUsers && connectedUsers.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead class="table-light border-0">
                  <tr class="rounded-3">
                    <th class="border-0 rounded-start-3">HOSTNAME</th>
                    <th class="border-0">ALAMAT IP</th>
                    <th class="border-0">MAC ADDRESS</th>
                    <th class="border-0">INTERFACE</th>
                    <th class="border-0 rounded-end-3 text-center">STATUS</th>
                  </tr>
                </thead>
                <tbody>
                  <% connectedUsers.forEach(function(user) { %>
                    <tr class="border-bottom">
                      <td class="py-3"><div class="fw-600"><%= user.hostname %></div></td>
                      <td><span class="text-muted"><%= user.ip %></span></td>
                      <td><small class="font-monospace text-secondary"><%= user.mac %></small></td>
                      <td><span class="badge bg-light text-dark fw-normal"><%= user.iface %></span></td>
                      <td class="text-center">
                        <span class="badge rounded-pill <%= user.status === 'Online' ? 'bg-success' : 'bg-secondary' %> px-3">
                          <%= user.status %>
                        </span>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } else { %>
            <div class="text-center py-5">
              <i class="bi bi-wifi-off display-1 text-light mb-3"></i>
              <p class="text-muted mb-0">Tidak ada perangkat yang aktif terhubung saat ini.</p>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="text-center mt-5 text-muted small">
      &copy; <%= new Date().getFullYear() %> <strong><%= settings.company_header %></strong>. All Rights Reserved.
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Reboot Confirmation
    document.getElementById('rebootBtn')?.addEventListener('click', function(e) {
      if (confirm('Anda yakin ingin mereboot perangkat ONU? Koneksi internet akan terputus selama beberapa menit.')) {
        const btn = this;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Memproses Reboot...';
        document.getElementById('rebootForm').submit();
      }
    });

    // Form Loading State
    document.querySelectorAll('.cmd-form').forEach(form => {
      form.addEventListener('submit', function() {
        const btn = this.querySelector('.btn-submit');
        if (btn) {
          btn.disabled = true;
          btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
        }
      });
    });

    // Auto Hide Notif
    setTimeout(() => {
      const alert = document.getElementById('notif-alert');
      if (alert) {
        const bsAlert = new bootstrap.Alert(alert);
        bsAlert.close();
      }
    }, 5000);
  </script>
</body>
</html>
 