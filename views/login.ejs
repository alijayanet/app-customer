<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login Pelanggan | <%= settings.company_header %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body {
      background: radial-gradient(circle at 0% 0%, #667eea 0%, transparent 40%),
                  radial-gradient(circle at 100% 100%, #764ba2 0%, transparent 40%),
                  #eef2ff;
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-box {
      width: 100%;
      max-width: 440px;
      padding: 20px;
    }
    .login-header-p {
      background: var(--primary-gradient);
      padding: 40px 20px;
      border-radius: 20px 20px 0 0;
      text-align: center;
      color: white;
    }
    .login-form-container {
      background: white;
      padding: 40px;
      border-radius: 0 0 20px 20px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }
    .form-control-p {
      border: 2px solid #edeff2;
      border-radius: 12px;
      padding: 12px 16px;
      font-size: 15px;
      transition: all 0.3s ease;
    }
    .form-control-p:focus {
      border-color: #667eea;
      box-shadow: 0 0 0 0.2rem rgba(102, 126, 234, 0.1);
    }
    .login-logo {
      width: 80px;
      height: 80px;
      background: white;
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 20px;
      box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }
  </style>
</head>
<body>
  <div class="login-box">
    <div class="card-premium overflow-hidden border-0">
      <div class="login-header-p">
        <div class="login-logo">
          <img src="/img/logo.png" alt="Logo" width="50">
        </div>
        <h3 class="fw-bold mb-1">Portal Pelanggan</h3>
        <p class="mb-0 opacity-75 small"><%= settings.company_header %></p>
      </div>
      
      <div class="login-form-container">
        <p class="text-center text-muted mb-4 small">Silakan masuk menggunakan ID atau Nomor WhatsApp yang terdaftar di sistem kami.</p>
        
        <form method="POST" action="/customer/login" id="loginForm">
          <div class="mb-3">
            <label class="form-label small fw-bold text-muted">ID / TAG PELANGGAN</label>
            <div class="input-group">
              <span class="input-group-text bg-light border-0 rounded-start-3"><i class="bi bi-person-vcard"></i></span>
              <input type="text" class="form-control form-control-p border-0 bg-light rounded-end-3" name="phone" placeholder="Contoh: 0812XXX" required autofocus>
            </div>
          </div>

          <% if (error) { %>
            <div class="alert alert-danger py-2 small border-0 mb-3">
              <i class="bi bi-exclamation-circle me-1"></i><%= error %>
            </div>
          <% } %>

          <button type="submit" class="btn btn-primary-p w-100 py-3 rounded-pill mt-2 fw-bold" id="loginBtn">
            Masuk Sekarang
          </button>
        </form>

        <div class="text-center mt-4 pt-3 border-top">
          <p class="text-muted x-small mb-0">
            &copy; <%= new Date().getFullYear() %> <strong><%= settings.company_header %></strong><br>
            Internet Tanpa Batas
          </p>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('loginForm').addEventListener('submit', function() {
      const btn = document.getElementById('loginBtn');
      btn.disabled = true;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Memeriksa ID...';
    });
  </script>
</body>
</html>
 